PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=dating_app
JWT_SECRET=change-this-to-a-long-random-string
BASE_URL=http://localhost:3000
OTP_TTL_MINUTES=5

# Resend email (password reset) — https://resend.com/docs/send-with-nodejs
EMAIL_PROVIDER=resend
RESEND_API_KEY=
PASSWORD_RESET_EMAIL_FROM=onboarding@resend.dev
PASSWORD_RESET_EMAIL_FROM_NAME=Spark Dating

# Bird email (optional fallback) — https://bird.com/en-us/docs/guides/email/sending-email
# EMAIL_PROVIDER=bird
BIRD_WORKSPACE_ID=ws_01kwy5m1she1m8a1jm5g7dmqf8
BIRD_API_KEY=

# Tmailor test inbox (optional — for reading reset codes at devflow@tokmail.net)
TEMPMAIL_EMAIL=devflow@tokmail.net
TEMPMAIL_ACCESS_TOKEN=
TEMPMAIL_INBOX_URL=

# Africa's Talking SMS (phone sign-in OTP)
SMS_PROVIDER=africas_talking
AFRICAS_TALKING_USERNAME=devflow@tokmail.net
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=Spark

# Termii email OTP (optional alternative) — https://developers.termii.com/email-token
# EMAIL_PROVIDER=termii
# TERMII_API_KEY=
# TERMII_BASE_URL=https://api.ng.termii.com
# TERMII_EMAIL_CONFIG_ID=

# Local dev only: show OTP in API response when email/SMS delivery is unavailable
# EXPOSE_OTP=true

# Bird SMS — https://bird.com/dashboard (access keys start with bk_eu1_)
# SMS_PROVIDER=bird
# BIRD_WORKSPACE_ID=ws_01kwy5m1she1m8a1jm5g7dmqf8
